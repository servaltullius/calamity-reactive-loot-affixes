{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CalamityAffixes Affix Spec",
  "type": "object",
  "required": ["version", "modKey", "eslFlag", "keywords"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "modKey": { "type": "string", "minLength": 5 },
    "eslFlag": { "type": "boolean" },
    "loot": { "$ref": "#/$defs/loot" },
    "keywords": {
      "type": "object",
      "required": ["tags", "affixes", "kidRules", "spidRules"],
      "additionalProperties": false,
      "properties": {
        "tags": {
          "type": "array",
          "items": { "$ref": "#/$defs/keyword" }
        },
        "affixes": {
          "type": "array",
          "items": { "$ref": "#/$defs/affix" }
        },
        "kidRules": {
          "type": "array",
          "items": { "$ref": "#/$defs/kidRule" }
        },
        "spidRules": {
          "type": "array",
          "items": { "$ref": "#/$defs/spidRule" }
        },
        "appendedMagicEffects": {
          "type": "array",
          "prefixItems": [
            {
              "allOf": [
                { "$ref": "#/$defs/magicEffectRecord" },
                { "properties": { "editorId": { "const": "CAFF_MGEF_RW_DRAGON_RESIST_FIRE" } } }
              ]
            },
            {
              "allOf": [
                { "$ref": "#/$defs/magicEffectRecord" },
                { "properties": { "editorId": { "const": "CAFF_MGEF_RW_DRAGON_RESIST_FROST" } } }
              ]
            },
            {
              "allOf": [
                { "$ref": "#/$defs/magicEffectRecord" },
                { "properties": { "editorId": { "const": "CAFF_MGEF_RW_DRAGON_RESIST_SHOCK" } } }
              ]
            }
          ],
          "items": false,
          "minItems": 3,
          "maxItems": 3
        },
        "appendedRecords": {
          "type": "array",
          "items": { "$ref": "#/$defs/appendedRecord" },
          "minItems": 1
        }
      }
    }
  },
  "$defs": {
    "loot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "chancePercent": { "type": "number", "minimum": 0.0, "maximum": 100.0 },
        "runewordFragmentChancePercent": { "type": "number", "minimum": 0.0, "maximum": 100.0 },
        "reforgeOrbChancePercent": { "type": "number", "minimum": 0.0, "maximum": 100.0 },
        "uniqueActorGuaranteedRunewordChancePercent": { "type": "number", "minimum": 0.0, "maximum": 100.0 },
        "currencyDropMode": { "type": "string", "enum": ["hybrid"] },
        "lootSourceChanceMultCorpse": { "type": "number", "minimum": 0.0, "maximum": 5.0 },
        "lootSourceChanceMultContainer": { "type": "number", "minimum": 0.0, "maximum": 5.0 },
        "lootSourceChanceMultBossContainer": { "type": "number", "minimum": 0.0, "maximum": 5.0 },
        "lootSourceChanceMultWorld": { "type": "number", "minimum": 0.0, "maximum": 5.0 },
        "renameItem": { "type": "boolean" },
        "nameMarkerPosition": { "type": "string", "enum": ["leading", "trailing"] },
        "sharedPool": { "type": "boolean" },
        "debugLog": { "type": "boolean" },
        "debugHudNotifications": { "type": "boolean" },
        "debugVerboseLogging": { "type": "boolean" },
        "dotTagSafetyAutoDisable": { "type": "boolean" },
        "dotTagSafetyUniqueEffectThreshold": { "type": "integer", "minimum": 0, "maximum": 4096 },
        "trapGlobalMaxActive": { "type": "integer", "minimum": 0, "maximum": 4096 },
        "trapCastBudgetPerTick": { "type": "integer", "minimum": 0, "maximum": 256 },
        "triggerProcBudgetPerWindow": { "type": "integer", "minimum": 0, "maximum": 512 },
        "triggerProcBudgetWindowMs": { "type": "integer", "minimum": 0, "maximum": 5000 },
        "cleanupInvalidLegacyAffixes": { "type": "boolean" },
        "stripTrackedSuffixSlots": { "type": "boolean" },
        "armorEditorIdDenyContains": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "bossContainerEditorIdAllowContains": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "bossContainerEditorIdDenyContains": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "nameFormat": { "type": "string" }
      }
    },
    "keyword": {
      "type": "object",
      "required": ["editorId", "name"],
      "additionalProperties": false,
      "properties": {
        "editorId": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "kid": {
      "type": "object",
      "required": ["type", "strings", "formFilters", "traits", "chance"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "strings": { "type": "string" },
        "formFilters": { "type": "string" },
        "traits": { "type": "string" },
        "chance": { "type": "number", "minimum": 0.0, "maximum": 100.0 }
      }
    },
    "affix": {
      "type": "object",
      "required": ["id", "editorId", "name", "kid", "runtime"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "editorId": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "nameEn": { "type": "string" },
        "nameKo": { "type": "string" },
        "slot": { "type": "string" },
        "family": { "type": ["string", "null"] },
        "weaponSubtypes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["OneHandedMelee", "TwoHandedMelee", "Bow", "Crossbow"]
          }
        },
        "records": {
          "oneOf": [
            { "$ref": "#/$defs/records" },
            { "type": "null" }
          ]
        },
        "kid": { "$ref": "#/$defs/kid" },
        "runtime": { "$ref": "#/$defs/runtime" }
      }
    },
    "runtime": {
      "type": "object",
      "properties": {
        "action": { "$ref": "#/$defs/runtimeAction" }
      }
    },
    "runtimeAction": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "feedback": { "$ref": "#/$defs/actionFeedback" },
        "trapFeedback": { "$ref": "#/$defs/trapFeedback" }
      },
      "allOf": [
        {
          "if": { "required": ["trapFeedback"] },
          "then": { "properties": { "type": { "const": "SpawnTrap" } } }
        },
        {
          "if": {
            "required": ["feedback"],
            "properties": { "feedback": { "properties": { "target": { "const": "Corpse" } } } }
          },
          "then": { "properties": { "type": { "enum": ["CorpseExplosion", "SummonCorpseExplosion"] } } }
        }
      ]
    },
    "actionFeedback": {
      "type": "object",
      "required": ["target", "playOn"],
      "additionalProperties": false,
      "properties": {
        "artObjectEditorId": { "type": "string", "minLength": 1 },
        "soundForm": { "type": "string", "pattern": "^[^|]+\\|0[xX][0-9A-Fa-f]+$" },
        "target": { "type": "string", "enum": ["Owner", "Target", "Corpse"] },
        "durationSeconds": { "type": "number", "minimum": 0.05, "maximum": 2.0 },
        "playOn": { "type": "string", "enum": ["Proc", "PassiveAdd"] },
        "spatialSound": { "type": "boolean" }
      },
      "anyOf": [
        { "required": ["artObjectEditorId", "durationSeconds"] },
        { "required": ["soundForm"] }
      ]
    },
    "trapFeedback": {
      "type": "object",
      "required": ["markerArtObjectEditorId", "unarmedScale", "armedScale"],
      "additionalProperties": false,
      "properties": {
        "markerArtObjectEditorId": { "type": "string", "minLength": 1 },
        "unarmedScale": { "type": "number", "minimum": 0.1, "maximum": 4.0 },
        "armedScale": { "type": "number", "minimum": 0.1, "maximum": 4.0 },
        "placed": { "$ref": "#/$defs/trapFeedbackCue" },
        "armed": { "$ref": "#/$defs/trapFeedbackCue" },
        "triggered": { "$ref": "#/$defs/trapFeedbackCue" },
        "expired": { "$ref": "#/$defs/trapFeedbackCue" }
      }
    },
    "trapFeedbackCue": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artObjectEditorId": { "type": "string", "minLength": 1 },
        "soundForm": { "type": "string", "pattern": "^[^|]+\\|0[xX][0-9A-Fa-f]+$" },
        "durationSeconds": { "type": "number", "minimum": 0.05, "maximum": 2.0 },
        "scale": { "type": "number", "minimum": 0.1, "maximum": 4.0 }
      },
      "anyOf": [
        { "required": ["artObjectEditorId", "durationSeconds"] },
        { "required": ["soundForm"] }
      ]
    },
    "kidRule": {
      "type": "object",
      "required": ["keywordEditorId", "type", "strings", "formFilters", "traits", "chance"],
      "additionalProperties": false,
      "properties": {
        "comment": { "type": "string" },
        "keywordEditorId": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "strings": { "type": "string" },
        "formFilters": { "type": "string" },
        "traits": { "type": "string" },
        "chance": { "type": "number", "minimum": 0.0, "maximum": 100.0 }
      }
    },
    "records": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "magicEffect": { "$ref": "#/$defs/magicEffectRecord" },
        "magicEffects": {
          "type": "array",
          "items": { "$ref": "#/$defs/magicEffectRecord" },
          "minItems": 1
        },
        "spell": { "$ref": "#/$defs/spellRecord" },
        "spells": {
          "type": "array",
          "items": { "$ref": "#/$defs/spellRecord" },
          "minItems": 1
        }
      },
      "anyOf": [
        { "required": ["magicEffect"] },
        { "required": ["magicEffects"] },
        { "required": ["spell"] },
        { "required": ["spells"] }
      ]
    },
    "magicEffectRecord": {
      "type": "object",
      "required": ["editorId", "actorValue"],
      "additionalProperties": false,
      "properties": {
        "editorId": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "actorValue": { "type": "string", "minLength": 1 },
        "resistValue": { "type": ["string", "null"] },
        "magicSkill": { "type": ["string", "null"] },
        "archetype": { "type": ["string", "null"] },
        "hostile": { "type": "boolean" },
        "recover": { "type": "boolean" }
      }
    },
    "appendedRecord": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "magicEffect"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "MagicEffect" },
            "magicEffect": { "$ref": "#/$defs/magicEffectRecord" }
          }
        },
        {
          "type": "object",
          "required": ["type", "spell"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "Spell" },
            "spell": { "$ref": "#/$defs/spellRecord" }
          }
        },
        {
          "type": "object",
          "required": ["type", "artObject"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "ArtObject" },
            "artObject": { "$ref": "#/$defs/artObjectRecord" }
          }
        }
      ]
    },
    "artObjectRecord": {
      "type": "object",
      "required": ["editorId", "modelPath", "artType"],
      "additionalProperties": false,
      "properties": {
        "editorId": { "type": "string", "minLength": 1 },
        "modelPath": { "type": "string", "minLength": 1 },
        "artType": {
          "type": "string",
          "enum": ["MagicHitEffect"]
        }
      }
    },
    "spellRecord": {
      "type": "object",
      "required": ["editorId", "delivery"],
      "additionalProperties": false,
      "properties": {
        "editorId": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "delivery": { "type": "string", "enum": ["Self", "TargetActor"] },
        "spellType": { "type": ["string", "null"] },
        "castType": { "type": ["string", "null"] },
        "effect": { "$ref": "#/$defs/spellEffectRecord" },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/spellEffectRecord" },
          "minItems": 1
        }
      },
      "anyOf": [
        { "required": ["effect"] },
        { "required": ["effects"] }
      ]
    },
    "spellEffectRecord": {
      "type": "object",
      "required": ["magicEffectEditorId", "magnitude", "duration", "area"],
      "additionalProperties": false,
      "properties": {
        "magicEffectEditorId": { "type": "string", "minLength": 1 },
        "magnitude": { "type": "number" },
        "duration": { "type": "integer", "minimum": 0 },
        "area": { "type": "integer", "minimum": 0 }
      }
    },
    "spidRule": {
      "type": "object",
      "required": ["line"],
      "additionalProperties": false,
      "properties": {
        "comment": { "type": "string" },
        "line": { "type": "string", "minLength": 1 }
      }
    }
  }
}
